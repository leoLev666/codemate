# DeepSeek API Key — get yours at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API base URL (default is the official endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model name
DEEPSEEK_MODEL=deepseek-chat

# Database (SQLite for local use, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/codemate.db

# ChromaDB persist directory
CHROMA_PERSIST_DIR=./data/chroma

# Embedding model (local, no API cost)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HuggingFace endpoint (use mirror for faster downloads in China)
HF_ENDPOINT=https://hf-mirror.com

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
RETRIEVAL_TOP_K=4

# Experimental features (set to true to enable)
HYBRID_SEARCH_ENABLED=false
RERANKER_ENABLED=false

# Docker sandbox
DOCKER_SANDBOX_IMAGE=codemate-sandbox
SANDBOX_TIMEOUT=10
SANDBOX_MEMORY_LIMIT=128m

# Agent
AGENT_MAX_STEPS=5

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
